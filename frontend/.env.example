# WalletConnect / Reown project ID used by RainbowKit.
# Create `frontend/.env` from this file and replace with your real project ID.
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional contract overrides.
# BASE Sepolia currently defaults to the deployed V2 address in src/config/contracts.ts,
# but setting the env keeps local testing explicit.
VITE_BASE_SEPOLIA_GAME_ADDRESS_V2=0xf031019A2A1DcEee8dAc3a7B9bf3066ced493292

# Optional override for the Base Sepolia srUSDC token used by the faucet flow.
VITE_BASE_SEPOLIA_TOKEN_ADDRESS=0x8eb2C48C23fdaF506Eb6CB0397A3861AdA57a9dA
