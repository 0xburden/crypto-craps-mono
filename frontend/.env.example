# WalletConnect Cloud project ID (required for wallet connect)
# Get one free at https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=

# CrapsGame contract addresses
# Sepolia: live deployment (0x6cBA1d9071c6900fE55a0aBf93dAaD363Da8919A)
# Mainnet: must be provided after Phase 10 deployment
VITE_SEPOLIA_CONTRACT_ADDRESS=0x6cBA1d9071c6900fE55a0aBf93dAaD363Da8919A
VITE_MAINNET_CONTRACT_ADDRESS=

# Token addresses
# Sepolia: project's mintable rehearsal token srUSDC (6 decimals)
#   Contract: 0x8eb2C48C23fdaF506Eb6CB0397A3861AdA57a9dA
# Mainnet: Circle USDC on BASE (0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913)
VITE_SEPOLIA_TOKEN_ADDRESS=0x8eb2C48C23fdaF506Eb6CB0397A3861AdA57a9dA
VITE_MAINNET_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Default chain: 'baseSepolia' or 'base'
VITE_DEFAULT_CHAIN=baseSepolia
