{
  "name": "crypto-craps",
  "version": "1.0.0",
  "description": "On-chain craps on BASE",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "test": "HARDHAT_SOURCES=./test/solidity hardhat test",
    "coverage": "HARDHAT_SOURCES=./test/solidity TS_NODE_CACHE=false DISABLE_V8_COMPILE_CACHE=1 hardhat coverage",
    "coverage:vault": "HARDHAT_SOURCES=./test/solidity TS_NODE_CACHE=false DISABLE_V8_COMPILE_CACHE=1 hardhat coverage --testfiles 'test/unit/Vault.test.ts' && node scripts/check-vault-coverage.mjs",
    "node": "hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^0.15",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15",
    "@nomicfoundation/hardhat-toolbox": "^5",
    "hardhat": "^2.22",
    "hardhat-gas-reporter": "^2",
    "solidity-coverage": "^0.8",
    "ts-node": "^10.9",
    "typescript": "^5"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.2",
    "@openzeppelin/contracts": "^5.1",
    "dotenv": "^16.4.7"
  }
}
